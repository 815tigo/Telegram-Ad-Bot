APP_NAME=telegram-ad-automation
ENVIRONMENT=dev
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/app.db

TELEGRAM_API_ID=0
